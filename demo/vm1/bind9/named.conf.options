options {
    directory "/var/cache/bind";

    // Encaminha consultas externas para Cloudflare e Google.
    forwarders { 1.1.1.1; 8.8.8.8; };
    forward only;

    dnssec-validation no;

    listen-on     { any; };
    listen-on-v6  { any; };
    allow-query   { any; };
    allow-recursion { any; };
};
