---
- name: Gerir VM2 App Stack (já existe)
  hosts: apps
  become: true
  vars:
    stack_path: /opt/technova-app
  tasks:
    - name: Verificar Docker
      service: name=docker state=started enabled=yes

    - name: docker compose ps (status)
      community.docker.docker_compose_v2:
        project_src: "{{ stack_path }}"
        state: present  # up -d se down

    - name: Test web
      uri: url=http://localhost:8080/api/health status_code=200
      retries: 5
