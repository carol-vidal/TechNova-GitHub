2026-04-17 01:24:38,779 p=4380 u=deploy n=ansible | srv-apps | CHANGED | rc=0 >>
#!/bin/bash
MYHOST="apps"
VM3="10.0.0.30"
echo "[$(date)] Watcher iniciado em $MYHOST"
while inotifywait -e modify /etc/shadow 2>/dev/null; do
  echo "[$(date)] Shadow mudou em $MYHOST"
  sleep 2
  ssh -o StrictHostKeyChecking=no deploy@${VM3} \
    "flock -n /tmp/sync-users.lock \
     /opt/technova-automation/scripts/sync-users.sh ${MYHOST}"
done

